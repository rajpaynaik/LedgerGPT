# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ledger:ledger@localhost:5432/ledgergpt
TIMESCALE_ENABLED=true

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_SOCIAL=raw.social
KAFKA_TOPIC_RAW_NEWS=raw.news
KAFKA_TOPIC_SENTIMENT=processed.sentiment
KAFKA_TOPIC_SIGNALS=trading.signals
KAFKA_GROUP_ID=ledgergpt-consumer

# ── Twitter/X ─────────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# ── Reddit ────────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=LedgerGPT/1.0

# ── News API ─────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key

# ── Market Data ───────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_key
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── FinLLaMA ─────────────────────────────────────────────────────────────────
FINLLAMA_MODEL_ID=FinLLaMA/FinLLaMA-3-8B
FINLLAMA_DEVICE=cuda
FINLLAMA_MAX_NEW_TOKENS=256
FINLLAMA_BATCH_SIZE=8
FINLLAMA_QUANTIZE=true

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_ARTIFACT_PATH=./artifacts/signal_model.pkl
FEATURE_STORE_PATH=./artifacts/features/
RETRAIN_SCHEDULE_HOURS=24

# ── Broker Execution ─────────────────────────────────────────────────────────
BROKER=alpaca
PAPER_TRADING=true
MAX_POSITION_SIZE_USD=10000
RISK_PER_TRADE_PCT=0.02

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
SENTRY_DSN=your_sentry_dsn
